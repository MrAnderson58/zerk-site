{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    {
      "source": "/product.html",
      "has": [{ "type": "query", "key": "id" }],
      "destination": "/product",
      "permanent": true
    },
    { "source": "/product.html", "destination": "/collection", "permanent": true },
    { "source": "/nitrile-gloves/ng-100-s", "destination": "/nitrile-gloves/ng-100-black-s", "permanent": true },
    { "source": "/nitrile-gloves/ng-100-m", "destination": "/nitrile-gloves/ng-100-black-m", "permanent": true },
    { "source": "/nitrile-gloves/ng-100-l", "destination": "/nitrile-gloves/ng-100-black-m", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/googlec9d2a993ca7c401d.html",
      "destination": "/googlec9d2a993ca7c401d"
    },
    { "source": "/nippers/:model/:variant", "destination": "/product" },
    { "source": "/nippers/:slug", "destination": "/product" },
    { "source": "/scissors/:slug", "destination": "/product" },
    { "source": "/pushers/:slug", "destination": "/product" },
    { "source": "/replaceable-files/:slug", "destination": "/product" },
    { "source": "/nitrile-gloves/:slug", "destination": "/product" }
  ],
  "headers": [
    {
      "source": "/googlec9d2a993ca7c401d.html",
      "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
